# ===========================================
# Git Push Tracker - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -------------------------------------------
# Required
# -------------------------------------------

# Google Gemini API key — get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Admin dashboard credentials (used for basic auth on /admin)
ADMIN_USER=admin
ADMIN_PASS=your-secure-password

# -------------------------------------------
# Optional (defaults shown)
# -------------------------------------------

# Server port
PORT=3000

# SQLite database file path (created automatically)
DATABASE_PATH=./data/pushlog.db

# How often the background worker checks for pending pushes (ms)
WORKER_INTERVAL_MS=10000

# Max retry attempts for Gemini API calls before marking a push as failed
MAX_RETRY_ATTEMPTS=3

# Gemini model to use for generating summaries
# Options: gemini-2.5-flash-lite (fast/cheap), gemini-2.5-flash (balanced), gemini-2.5-pro (best quality)
GEMINI_MODEL=gemini-2.5-flash-lite
